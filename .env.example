# claude-container configuration.
#
# Copy this to `.env` and uncomment/edit what you need:  cp .env.example .env
# Nothing set = a plain Claude Code sandbox. `.env` is gitignored - never commit it.
# compose loads it automatically (env_file), so these become the container's env.

# --- Container ---------------------------------------------------------------
# Shown as the session "origin" in claude.ai/code (default: claude-container).
#CONTAINER_HOSTNAME=Docker

# --- Forgejo (opinionated) ---------------------------------------------------
# Set these three and you get the baked `forgejo` wrapper (issues + commit-via-API)
# plus the launcher auto-cloning repos by name from your org. (Gitea's API is
# compatible and likely works, but only Forgejo is a support goal.)
#FORGE_HOST=https://git.example.com
#FORGE_ORG=your-org
#FORGE_TOKEN=your_forgejo_token        # used by the wrapper AND, by default, for clones

# --- Launcher / sessions -----------------------------------------------------
#WORKDIR=/workspace                    # where sessions launch ($WORKDIR/<name>)
# Where repos pulled from your forge org launch. Defaults to WORKDIR. Point it at a
# canonical clones directory to avoid duplicate checkouts of org repos (e.g. if a
# SessionStart hook manages clones under ~/.claude/agent-projects):
#FORGE_WORKDIR=/home/node/.claude/agent-projects
#WEB_NAME_PREFIX=[MyHost]              # cc-control -> "<prefix> 🛠️ Control"; sessions -> "<prefix> <repo>"
#PERMISSION_MODE=acceptEdits           # claude permission mode
# Auto-clone base (defaults to $FORGE_HOST/$FORGE_ORG when those are set; any git host):
#GIT_BASE=https://github.com/your-org
#GIT_USER=git                          # basic-auth username paired with the token
#GIT_TOKEN=...                         # defaults to FORGE_TOKEN

# --- Personalisation hook (optional) -----------------------------------------
# At first-setup, clone a repo and run its entrypoint (your dotfiles / agent-memory).
#SETUP_REPO=https://git.example.com/your-org/your-setup.git
#SETUP_USER=git
#SETUP_TOKEN=...                       # defaults to FORGE_TOKEN
#SETUP_ENTRYPOINT=install.sh
#SETUP_TOKEN_FILE=/home/node/.config/forgejo-claude/token   # if your setup expects a token file
